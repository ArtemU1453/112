{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "npm",
  "useNx": false,
  "command": {
    "publish": {
      "conventionalCommits": true,
      "createRelease": "github"
    },
    "bootstrap": {
      "npmClientArgs": ["--legacy-peer-deps"]
    }
  },
  "packages": [
    "services/*",
    "shared/*"
  ]
}
