{
  "name": "easur-platform",
  "version": "1.0.0",
  "description": "Интегрированная система управления чрезвычайными ситуациями и диспетчеризации",
  "private": true,
  "workspaces": [
    "services/*",
    "shared/*",
    "infrastructure/*"
  ],
  "scripts": {
    "install-all": "npm install && npm run bootstrap",
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "dev": "lerna run dev --parallel",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "docker:build": "lerna run docker:build",
    "docker:push": "lerna run docker:push"
  },
  "devDependencies": {
    "lerna": "^6.0.0",
    "npm-workspace": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "emergency",
    "dispatch",
    "platform",
    "microservices"
  ],
  "license": "MIT"
}
