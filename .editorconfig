# ЕАСУР — единые настройки редактора (Toolchain Governance Standard, Coding Standards)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx,json,css,scss,html}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{xml,pom}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bat,cmd}]
indent_size = 2
