# EASUR Platform - Environment Variables Example
# Copy this file to .env in each service directory and fill in the values

# ====================
# Database
# ====================
DATABASE_URL=postgresql://easur:easur_dev@localhost:5432/easur
MONGO_URL=mongodb://easur:easur_dev@localhost:27017/easur?authSource=admin

# ====================
# Cache & Message Broker
# ====================
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://easur:easur_dev@localhost:5672

# ====================
# Services URLs (for inter-service communication)
# ====================
AUTH_SERVICE_URL=http://localhost:3000
INCIDENT_SERVICE_URL=http://localhost:3001
DISPATCH_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3003
GIS_SERVICE_URL=http://localhost:3004
REALTIME_SERVICE_URL=http://localhost:3005
TELEPHONY_SERVICE_URL=http://localhost:3006
AI_SERVICE_URL=http://localhost:3007
AUDIT_SERVICE_URL=http://localhost:3008

# ====================
# Authentication
# ====================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ====================
# Logging
# ====================
LOG_LEVEL=info
LOG_FORMAT=json

# ====================
# Monitoring
# ====================
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_HOST=localhost
JAEGER_PORT=6831

# ====================
# Environment
# ====================
NODE_ENV=development
APP_NAME=easur-platform
APP_VERSION=1.0.0
PORT=3000

# ====================
# Elasticsearch (for logging)
# ====================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ====================
# Email (for notifications)
# ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@easur.com

# ====================
# SMS (for notifications)
# ====================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ====================
# Third-party APIs
# ====================
GOOGLE_MAPS_API_KEY=your_api_key
OPENWEATHER_API_KEY=your_api_key

# ====================
# External Services
# ====================
EXTERNAL_GIS_API_URL=https://api.example.com/gis
EXTERNAL_TELEPHONY_URL=https://telephony.example.com

# ====================
# Security
# ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:4200
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=15m

# ====================
# File Storage
# ====================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# или для S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=your_bucket
# AWS_S3_REGION=us-east-1

# ====================
# Feature Flags
# ====================
FEATURE_AI_ENABLED=true
FEATURE_GIS_ENABLED=true
FEATURE_TELEPHONY_ENABLED=true

# ====================
# Sentry (Error Tracking)
# ====================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
