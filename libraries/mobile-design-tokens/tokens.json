{
  "$schema": "https://design-tokens.example/schema.json",
  "meta": {
    "name": "ЕАСУР Mobile Design Tokens",
    "version": "1.0.0",
    "description": "Единые токены мобильной дизайн-системы (Mobile Design System, Stage 7)."
  },
  "color": {
    "priority": {
      "critical": "#d32f2f",
      "high": "#f57c00",
      "medium": "#fbc02d",
      "low": "#388e3c"
    },
    "unitStatus": {
      "available": "#2e7d32",
      "dispatched": "#f9a825",
      "enRoute": "#1565c0",
      "onScene": "#6a1b9a",
      "returning": "#00838f",
      "outOfService": "#616161"
    },
    "semantic": {
      "success": "#2e7d32",
      "warning": "#f57c00",
      "error": "#c62828",
      "info": "#1565c0"
    },
    "theme": {
      "light": {
        "background": "#ffffff",
        "surface": "#f5f5f5",
        "onSurface": "#1a1a1a",
        "primary": "#c62828",
        "border": "#e0e0e0"
      },
      "dark": {
        "background": "#0d1117",
        "surface": "#161b22",
        "onSurface": "#e6edf3",
        "primary": "#ef5350",
        "border": "#30363d"
      },
      "highContrast": {
        "background": "#000000",
        "surface": "#000000",
        "onSurface": "#ffffff",
        "primary": "#ff5252",
        "border": "#ffffff"
      }
    }
  },
  "typography": {
    "fontFamily": "system",
    "scale": {
      "caption": 14,
      "body": 18,
      "title": 22,
      "headline": 28
    },
    "minScalableBody": 18
  },
  "spacing": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32 },
  "radius": { "sm": 4, "md": 8, "lg": 12 },
  "touchTarget": {
    "minDp": 48,
    "gloveModeMinDp": 64,
    "note": "Увеличенные зоны нажатия для работы в перчатках (Mobile Accessibility Standard)."
  }
}
